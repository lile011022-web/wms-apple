NODE_ENV=production
POSTGRES_USER=wms
POSTGRES_PASSWORD=change_me
POSTGRES_DB=wms_scan
DATABASE_URL=postgresql://wms:change_me@postgres:5432/wms_scan
REDIS_URL=redis://redis:6379
JWT_SECRET=change_me
JWT_ACCESS_SECRET=change_me_access_secret_at_least_16_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_16_chars
API_PORT=3000
WEB_DOMAIN=wms.example.com
WEB_ORIGIN=https://wms.example.com
VITE_API_BASE_URL=/api/v1

# Optional Google Sheets exchange for package prealerts.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_PREALERT_SHEET_NAME=预报
GOOGLE_SHEETS_STATUS_SHEET_NAME=状态

# Optional prebuilt-image deployment values for docker-compose.prod.images.yml.
# Replace repository and tag on the server only when USE_PREBUILT_IMAGES=true.
WEB_IMAGE=ghcr.io/owner/repository/web:latest
API_IMAGE=ghcr.io/owner/repository/api:latest
