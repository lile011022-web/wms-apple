NODE_ENV=development

DATABASE_URL=postgresql://wms_scan:wms_scan_dev_password@localhost:5432/wms_scan
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

WEB_PORT=5173
API_PORT=3000
WEB_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Package prealerts are kept in the codebase but disabled by default.
# Set both flags to true only when deciding to resume the prealert workflow.
PACKAGE_PREALERTS_ENABLED=false
VITE_ENABLE_PACKAGE_PREALERTS=false

# Optional Google Sheets exchange for package prealerts.
# Share the spreadsheet with the service account email as Editor.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_PREALERT_SHEET_NAME=预报
GOOGLE_SHEETS_STATUS_SHEET_NAME=状态

# Required only when running `pnpm --filter @wms-scan/api prisma:seed`.
SEED_ADMIN_PASSWORD=replace-with-local-development-password
