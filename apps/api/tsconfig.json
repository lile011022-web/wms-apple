{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "sourceMap": true,
    "strictPropertyInitialization": false,
    "types": ["node", "jest"],
    "paths": {
      "@wms-scan/shared": ["../../packages/shared/dist/index.d.ts"],
      "@wms-scan/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
